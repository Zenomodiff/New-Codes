#include <WiFi.h>
#include <DNSServer.h>
#include <WebServer.h>

// --- Configuration ---
const byte DNS_PORT = 53;
IPAddress apIP(192, 168, 4, 1);
DNSServer dnsServer;
WebServer server(80);

// Your provided Base64 string
const char* burgerImageBase64 = "data:image/webp;base64,";
";
// --- HTML Builder ---
String getHTML() {
  String html = "<!DOCTYPE html><html><head>";
  html += "<meta name='viewport' content='width=device-width, initial-scale=1'>";
  html += "<style>";
  html += "body { font-family: sans-serif; text-align: center; background-color: #f7f1e3; margin: 0; padding: 20px; }";
  html += ".container { background: white; max-width: 400px; margin: auto; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); overflow: hidden; }";
  html += "img { width: 100%; height: auto; display: block; }";
  html += ".content { padding: 25px; }";
  html += "h1 { color: #333; font-size: 24px; margin: 0; text-transform: uppercase; }";
  html += ".btn { display: inline-block; margin-top: 20px; padding: 15px 30px; background: #2d3436; color: white; text-decoration: none; border-radius: 50px; font-weight: bold; }";
  html += "</style></head><body>";
  
  html += "<div class='container'>";
  // This tag displays your Base64 burger image
  html += "<img src='" + String(burgerImageBase64) + "'>";
  html += "<div class='content'>";
  html += "<h1>Delicious Burger</h1>";
  html += "<p>Connected to <b>FREE WIFI</b>. Order now to satisfy your cravings!</p>";
  html += "<a href='#' class='btn'>ORDER NOW</a>";
  html += "</div></div></body></html>";
  
  return html;
}

// --- Routes ---
void handleRoot() {
  server.send(200, "text/html", getHTML());
}

void setup() {
  Serial.begin(115200);

  // 1. WiFi Access Point
  WiFi.mode(WIFI_AP);
  WiFi.softAPConfig(apIP, apIP, IPAddress(255, 255, 255, 0));
  WiFi.softAP("FREE WIFI"); 

  // 2. DNS Server (Intercepts all requests)
  dnsServer.start(DNS_PORT, "*", apIP);

  // 3. Web Server Routes
  server.on("/", handleRoot);
  
  // Common captive portal endpoints for mobile OS detection
  server.on("/generate_204", handleRoot); // Android
  server.on("/hotspot-detect.html", handleRoot); // iOS/MacOS
  
  server.onNotFound([]() {
    server.sendHeader("Location", String("http://") + apIP.toString(), true);
    server.send(302, "text/plain", "");
  });

  server.begin();
  Serial.println("Captive Portal is LIVE.");
}

void loop() {
  dnsServer.processNextRequest();
  server.handleClient();
}